# Production environment template for VPS deployment.
# Copy this file to /opt/entrance-chatbot/.env.production on the VPS.
# Never commit the real .env.production file.

ENVIRONMENT=production
LOG_LEVEL=INFO

# Docker image deployed by CI/CD.
# Example: ghcr.io/your-org/entrance-chatbot/backend:latest
BACKEND_IMAGE=ghcr.io/REPLACE_OWNER/REPLACE_REPO/backend:latest

# Java backend source API used for ingestion.
BACKEND_API_BASE_URL=https://api.entrancegateway.com/api/v1
BACKEND_API_PAGE_SIZE=100
CHATBOT_BACKEND_JWT=REPLACE_WITH_JAVA_BACKEND_JWT

# Ollama runs as an internal Docker service.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB runs as an internal Docker service.
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=entrance_knowledge

# Redis runs as an internal Docker service.
REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=3600
MAX_CHAT_HISTORY_MESSAGES=5

# Secrets. Replace with strong production values.
API_KEY=REPLACE_WITH_LONG_RANDOM_ADMIN_API_KEY
WEBHOOK_SECRET=

# Frontend origins allowed to call public chat APIs.
CORS_ORIGINS=https://entrancegateway.com,https://www.entrancegateway.com

# Rate limiting.
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# Keep workers low for VPS/Ollama memory stability.
UVICORN_WORKERS=1

# Retrieval tuning.
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_KEYWORD_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_MIN_RELEVANCE_SCORE=0.15

# Chunking.
CHUNK_SIZE_CHARS=600
CHUNK_OVERLAP_CHARS=120
